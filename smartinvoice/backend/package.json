{
  "name": "smartinvoice-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SmartInvoice backend — Express 4 + MongoDB 6, integer-paise, GST-compliant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "pdfkit": "^0.14.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "pdf-parse": "^1.1.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/schema.js",
      "!src/services/seedService.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90
      }
    }
  }
}
